# Devin
DEVIN_API_KEY=cog_replace_me
DEVIN_ORG_ID=org_replace_me
DEVIN_BASE_URL=https://api.devin.ai/v3

# GitHub
GITHUB_TOKEN=ghp_replace_me
GITHUB_REPO=sevensyeds/superset

# Superset checkout (used by Bandit scanner)
SUPERSET_PATH=/superset

# Scheduler — APScheduler cron expression
SCAN_CRON=*/10 * * * *

# Concurrency + budget guardrails
MAX_CONCURRENT_SESSIONS=2
MAX_ACU_PER_SESSION=10
SESSION_MAX_WALL_CLOCK_SECONDS=3600
POLL_INTERVAL_SECONDS=10

# Set true to serve canned Devin responses from tests/mocks/ (no real ACUs spent)
MOCK_DEVIN=false

# SQLite state path (mounted volume in docker compose)
DB_PATH=/data/state.db
